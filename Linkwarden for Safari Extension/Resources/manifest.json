{
    "manifest_version": 3,
    "default_locale": "en",

    "name": "Linkwarden for Safari",
    "description": "Save links to Linkwarden",
    "version": "1.0",

    "icons": {
        "48": "images/icon-48.png",
        "96": "images/icon-96.png",
        "128": "images/icon-128.png",
        "256": "images/icon-256.png",
        "512": "images/icon-512.png"
    },

    "content_scripts": [
        {
            "matches": ["<all_urls>"],
            "js": ["popup.js", "slimselect.min.js"]
        }
    ],

    "action": {
        "default_popup": "popup.html",
        "default_icon": "images/toolbar-icon.svg"
    },

    "permissions": [ 
        "storage",
        "activeTab"
    ],
    "options_page": "settings.html"
}
